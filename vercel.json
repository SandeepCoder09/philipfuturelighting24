{
    "cleanUrls": true,
  
    "redirects": [
      {
        "source": "/(.*)/index.html",
        "destination": "/$1",
        "permanent": true
      },
      {
        "source": "/index.html",
        "destination": "/",
        "permanent": true
      },
      {
        "source": "/:path*",
        "has": [
          {
            "type": "host",
            "value": "www.bright24futurelighting.com"
          }
        ],
        "destination": "https://bright24futurelighting.com/:path*",
        "permanent": true
      }
    ],
  
    "rewrites": [
      {
        "source": "/login",
        "destination": "/auth/login.html"
      },
      {
        "source": "/admin-login",
        "destination": "/admin/login.html"
      }
    ]
  }